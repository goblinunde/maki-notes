\newcommand{\MakiBeamerHeadline@durham}{%
	\begin{beamercolorbox}[
		wd=\paperwidth,
		ht=3ex,dp=2.0ex,
		leftskip=1.2em,rightskip=1.2em
	]{headline}
		\insertsectionnavigationhorizontal{\dimexpr\paperwidth-2.4em\relax}{}{}%
	\end{beamercolorbox}%
	\ifx\insertsubsectionhead\@empty
	\else
		\begin{beamercolorbox}[
			wd=\paperwidth,
			ht=2.7ex,dp=0.9ex,
			leftskip=1.3em,rightskip=1.2em
		]{headline second}
			\usebeamerfont{subsection in head/foot}%
			\MakiBeamerTrunc{\insertsubsectionhead}{\MakiBeamerMaxCharsSubHeadline}%
		\end{beamercolorbox}%
	\fi
}

\newcommand{\MakiBeamerHeadline@minimal}{%
	\begin{beamercolorbox}[
		wd=\paperwidth,
		ht=2.5ex,dp=1.0ex,
		leftskip=1.2em,rightskip=1.2em
	]{footline muted}
		\usebeamerfont{footline}%
		\color{MakiBodyColor}\insertshorttitle
		\hfill
		\color{MakiThemeColor}\MakiBeamerTrunc{\insertsectionhead}{\MakiBeamerMaxCharsHeadline}%
	\end{beamercolorbox}%
}

\newcommand{\MakiBeamerHeadline@splitbar}{%
	\begin{beamercolorbox}[
		wd=\paperwidth,
		ht=2.4ex,dp=1.0ex,
		leftskip=1.2em,rightskip=1.2em
	]{headline}
		\usebeamerfont{footline}\insertshorttitle
		\hfill
		\insertframenumber/\inserttotalframenumber
	\end{beamercolorbox}%
	\begin{beamercolorbox}[
		wd=\paperwidth,
		ht=2.8ex,dp=1.0ex,
		leftskip=1.2em,rightskip=1.2em
	]{headline second}
		{\color{MakiThemeColor}\bfseries\MakiBeamerTrunc{\insertsectionhead}{24}}%
		\ifx\insertsubsectionhead\@empty
		\else
			\hfill
			\usebeamerfont{subsection in head/foot}%
			\MakiBeamerTrunc{\insertsubsectionhead}{24}%
		\fi
	\end{beamercolorbox}%
}

