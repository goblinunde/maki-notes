			\fill[MakiThemeColor]
				([xshift=1.0cm,yshift=-1.1cm]current page.north west) rectangle
				([xshift=1.2cm,yshift=-0.82\paperheight]current page.north west);
		\end{tikzpicture}%
	}%
	\begin{frame}[plain,noframenumbering]
		\vspace*{1.3cm}
		\hspace*{1.45cm}%
		\begin{minipage}{0.74\paperwidth}
			{\usebeamerfont{title}\color{MakiThemeColor}\bfseries #1\par}%
			\vspace{0.6em}%
			{\color{MakiThemeColor}\rule{0.2\linewidth}{1pt}\par}%
			\vspace{1.1em}%
			\setlength{\parskip}{0pt}%
			\tableofcontents
		\end{minipage}
	\end{frame}
	\endgroup
}

