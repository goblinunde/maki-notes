\newcommand{\MakiBeamerValidateLayout}{%
	\ifcsname MakiBeamerTitlePage@\MakiBeamerLayout\endcsname
	\else
		\PackageError{beamerthememaki}{Unsupported layout `\MakiBeamerLayout'}{Valid values are durham, minimal, splitbar. Falling back to `durham'.}%
		\renewcommand{\MakiBeamerLayout}{durham}%
	\fi
}
\makeatother

