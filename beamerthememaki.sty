\newcommand{\MakiBeamerOutline@durham}[1]{%
	\begingroup
	\setbeamertemplate{background canvas}{%
		\begin{tikzpicture}[remember picture,overlay]
			\ifMakiBeamerInvert
				\fill[MakiThemeColor] (current page.south west) rectangle (current page.north east);
			\else
				\fill[MakiThemeColor]
					(current page.north west) rectangle
					([yshift=-0.19\paperheight]current page.north east);
			\fi
			\node[
				anchor=west,
				text=white,
				align=left,
				text width=0.78\paperwidth
			] at ([xshift=0.13\paperwidth,yshift=-0.095\paperheight]current page.north west) {%
				{\usebeamerfont{title}\bfseries #1}%
			};
		\end{tikzpicture}%
	}%
	\begin{frame}[plain,noframenumbering]
		\vspace*{0.19\paperheight}
		\hspace*{0.13\paperwidth}%
		\begin{minipage}{0.78\paperwidth}
			\setlength{\parskip}{0pt}%
			\tableofcontents
		\end{minipage}
	\end{frame}
	\endgroup
}

\newcommand{\MakiBeamerOutline@minimal}[1]{%
	\begingroup
