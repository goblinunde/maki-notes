\newcommand{\MakiBeamerTitlePage@durham}{%
	\begin{tikzpicture}[remember picture,overlay]
		\fill[MakiCanvasColor] (current page.south west) rectangle (current page.north east);
		\fill[MakiThemeColor]
			($(current page.south east)+(0,0)$) --
			($(current page.south east)+(-4.4cm,0)$) --
			($(current page.south east)+(0,4.4cm)$) -- cycle;
	\end{tikzpicture}
	\begin{tikzpicture}[remember picture,overlay]
		\node[
			anchor=north west,
			align=left,
			text width=0.8\paperwidth
		] at ($(current page.north west)+(1.2cm,-1.4cm)$) {%
			{\usebeamerfont{title}\color{MakiThemeColor}\inserttitle\par}%
			\ifx\insertsubtitle\@empty\else
				\vspace{0.45em}%
				{\usebeamerfont{subtitle}\color{MakiBodyColor}\insertsubtitle\par}%
			\fi
			\vspace{1.0em}%
			\MakiBeamerTitleRule
			\vspace{1.8em}%
			{\usebeamerfont{author}\color{MakiBodyColor}\insertauthor\par}%
			\ifx\insertinstitute\@empty\else
				\vspace{0.8em}%
				{\usebeamerfont{institute}\color{MakiBodyColor}\insertinstitute\par}%
			\fi
		};
	\end{tikzpicture}
	\begin{tikzpicture}[remember picture,overlay]
		\node[
			anchor=south east,
			text=white,
			align=right
		] at ($(current page.south east)+(-0.3cm,0.3cm)$) {%
			{\usebeamerfont{date}\insertdate}%
		};
	\end{tikzpicture}
}

