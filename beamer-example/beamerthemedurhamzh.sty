\newcommand{\DurhamZHSetupBundledLuaFonts}{%
  \setCJKsansfont{FandolHei-Regular}[BoldFont=FandolHei-Bold]%
  \setCJKmainfont{FandolSong-Regular}[BoldFont=FandolSong-Bold]%
  \setCJKmonofont{FandolFang-Regular}%
}
\newcommand{\DurhamZHSetupBundledXeFonts}{%
  % Let ctex choose the engine-native CJK fontset under XeLaTeX.
}
\newcommand{\DurhamZHUseBundledFonts}{%
  \ifLuaTeX
    \DurhamZHSetupBundledLuaFonts
  \fi
  \ifXeTeX
    \DurhamZHSetupBundledXeFonts
  \fi
}
\newcommand{\DurhamZHSetupLuaSystemFonts}{%
  \IfFontExistsTF{Noto Sans CJK SC}{%
    \setCJKsansfont{Noto Sans CJK SC}%
  }{%
    \setCJKsansfont{FandolHei-Regular}[BoldFont=FandolHei-Bold]%
  }%
  \IfFontExistsTF{Noto Serif CJK SC}{%
    \setCJKmainfont{Noto Serif CJK SC}%
  }{%
    \setCJKmainfont{FandolSong-Regular}[BoldFont=FandolSong-Bold]%
  }%
  \IfFontExistsTF{Noto Sans Mono CJK SC}{%
    \setCJKmonofont{Noto Sans Mono CJK SC}%
  }{%
    \setCJKmonofont{FandolFang-Regular}%
  }%
}
\newcommand{\DurhamZHSetupXeSystemFonts}{%
  \IfFontExistsTF{Microsoft YaHei}{%
    \setCJKsansfont{Microsoft YaHei}%
  }{%
    \IfFontExistsTF{PingFang SC}{%
      \setCJKsansfont{PingFang SC}%
    }{%
      \IfFontExistsTF{SimHei}{%
        \setCJKsansfont{SimHei}%
      }{%
        \setCJKsansfont{FandolHei-Regular}[BoldFont=FandolHei-Bold]%
      }%
    }%
  }%
  \IfFontExistsTF{SimSun}{%
    \IfFontExistsTF{SimHei}{%
      \setCJKmainfont{SimSun}[BoldFont=SimHei]%
    }{%
      \IfFontExistsTF{Microsoft YaHei}{%
        \setCJKmainfont{SimSun}[BoldFont=Microsoft YaHei]%
      }{%
        \setCJKmainfont{SimSun}%
      }%
    }%
  }{%
    \IfFontExistsTF{Songti SC}{%
      \setCJKmainfont{Songti SC}%
    }{%
      \setCJKmainfont{FandolSong-Regular}[BoldFont=FandolSong-Bold]%
    }%
  }%
  \IfFontExistsTF{NSimSun}{%
    \setCJKmonofont{NSimSun}%
  }{%
    \IfFontExistsTF{SimSun}{%
      \setCJKmonofont{SimSun}%
    }{%
      \setCJKmonofont{FandolFang-Regular}%
    }%
  }%
}
\newcommand{\DurhamZHUseSystemFonts}{%
  \ifLuaTeX
    \DurhamZHSetupLuaSystemFonts
  \fi
  \ifXeTeX
    \DurhamZHSetupXeSystemFonts
  \fi
}
\newcommand{\DurhamZHSetupFonts}{\DurhamZHUseBundledFonts}
\DurhamZHUseBundledFonts

\endinput
