\newtcolorbox{thmBox}[3][]{%
	commonbox,
	colback=LogicBg,
	colbacktitle=LogicColor,
	before title={\refstepcounter{theorem}},
	title={#2 \thetheorem\ifstrempty{#3}{}{（#3）}},
	#1
}

\newcounter{theorem}[chapter]
\renewcommand{\thetheorem}{\thechapter.\arabic{theorem}}

