\newcommand{\makisetlatinfonts}{%
	\IfFileExists{texgyrepagella-regular.otf}{%
		\setmainfont{texgyrepagella-regular.otf}[%
			BoldFont = texgyrepagella-bold.otf,
			ItalicFont = texgyrepagella-italic.otf,
			BoldItalicFont = texgyrepagella-bolditalic.otf
		]%
	}{%
		\setmainfont{lmroman10-regular.otf}[%
			BoldFont = lmroman10-bold.otf,
			ItalicFont = lmroman10-italic.otf,
			BoldItalicFont = lmroman10-bolditalic.otf
		]%
	}%
	\IfFileExists{texgyreheros-regular.otf}{%
		\setsansfont{texgyreheros-regular.otf}[%
			BoldFont = texgyreheros-bold.otf,
			ItalicFont = texgyreheros-italic.otf,
			BoldItalicFont = texgyreheros-bolditalic.otf
		]%
	}{}%
	\IfFileExists{lmmono10-regular.otf}{%
		\setmonofont{lmmono10-regular.otf}[%
			BoldFont = lmmonolt10-bold.otf,
			ItalicFont = lmmono10-italic.otf,
			BoldItalicFont = lmmonolt10-oblique.otf
		]%
	}{}%
}

\newcommand{\makisetcommoncjkfonts}{%
	\renewcommand{\MakiResolvedFontPreset}{common}%
	\setCJKmainfont{FandolSong-Regular.otf}[BoldFont = FandolSong-Bold.otf]%
	\setCJKsansfont{FandolHei-Regular.otf}%
	\setCJKmonofont{FandolFang-Regular.otf}%
	\setCJKfamilyfont{makiKai}{FandolKai-Regular.otf}%
	\setCJKfamilyfont{makiHeavyKai}{FandolKai-Regular.otf}[AutoFakeBold = 10]%
}

\newcommand{\makipickfirstfont}[2]{%
	\def\MakiPickedFont{}%
	\begingroup
	\renewcommand*{\do}[1]{%
		\ifdefempty{\MakiPickedFont}{%
			\IfFontExistsTF{##1}{\xdef\MakiPickedFont{##1}}{}%
		}{}%
	}%
	\docsvlist{#1}%
	\endgroup
	\ifdefempty{\MakiPickedFont}{%
		\edef\MakiPickedFont{#2}%
	}{}%
}

\newcommand{\makiapplyfontpresetcommon}{%
	\makisetcommoncjkfonts
}

\newcommand{\makiapplyfontpresetwindows}{%
	\IfFontExistsTF{SimSun}{%
		\renewcommand{\MakiResolvedFontPreset}{windows}%
		\setCJKmainfont{SimSun}[AutoFakeBold = 3]%
		\makipickfirstfont{Microsoft YaHei,SimHei,FandolHei-Regular.otf}{FandolHei-Regular.otf}%
		\setCJKsansfont{\MakiPickedFont}[AutoFakeBold = 2]%
		\makipickfirstfont{NSimSun,SimSun,FandolFang-Regular.otf}{FandolFang-Regular.otf}%
		\setCJKmonofont{\MakiPickedFont}%
		\makipickfirstfont{KaiTi,FandolKai-Regular.otf}{FandolKai-Regular.otf}%
		\setCJKfamilyfont{makiKai}{\MakiPickedFont}%
		\setCJKfamilyfont{makiHeavyKai}{\MakiPickedFont}[AutoFakeBold = 10]%
	}{%
		\PackageWarningNoLine{maki-notes}{Font preset `windows' requested but SimSun was not found. Falling back to `common'}%
		\makisetcommoncjkfonts
	}%
}

\newcommand{\makiapplyfontpresetmacos}{%
	\IfFontExistsTF{Songti SC}{%
		\renewcommand{\MakiResolvedFontPreset}{macos}%
		\setCJKmainfont{Songti SC}%
		\makipickfirstfont{PingFang SC,Heiti SC,STHeiti,FandolHei-Regular.otf}{FandolHei-Regular.otf}%
		\setCJKsansfont{\MakiPickedFont}%
		\makipickfirstfont{PingFang SC,SF Pro SC,FandolFang-Regular.otf}{FandolFang-Regular.otf}%
		\setCJKmonofont{\MakiPickedFont}%
		\makipickfirstfont{Kaiti SC,STKaiti,FandolKai-Regular.otf}{FandolKai-Regular.otf}%
		\setCJKfamilyfont{makiKai}{\MakiPickedFont}%
		\setCJKfamilyfont{makiHeavyKai}{\MakiPickedFont}[AutoFakeBold = 10]%
	}{%
		\PackageWarningNoLine{maki-notes}{Font preset `macos' requested but Songti SC was not found. Falling back to `common'}%
		\makisetcommoncjkfonts
	}%
}

\newcommand{\makiapplyfontpresetlinux}{%
	\IfFontExistsTF{Noto Serif CJK SC}{%
		\renewcommand{\MakiResolvedFontPreset}{linux}%
		\setCJKmainfont{Noto Serif CJK SC}%
		\makipickfirstfont{Noto Sans CJK SC,Source Han Sans SC,FandolHei-Regular.otf}{FandolHei-Regular.otf}%
		\setCJKsansfont{\MakiPickedFont}%
		\makipickfirstfont{Noto Sans Mono CJK SC,Noto Sans CJK SC,Source Han Sans SC,FandolFang-Regular.otf}{FandolFang-Regular.otf}%
		\setCJKmonofont{\MakiPickedFont}%
		\makipickfirstfont{LXGW WenKai,FandolKai-Regular.otf}{FandolKai-Regular.otf}%
		\setCJKfamilyfont{makiKai}{\MakiPickedFont}%
		\setCJKfamilyfont{makiHeavyKai}{\MakiPickedFont}[AutoFakeBold = 10]%
	}{%
		\IfFontExistsTF{Source Han Serif SC}{%
			\renewcommand{\MakiResolvedFontPreset}{linux}%
			\setCJKmainfont{Source Han Serif SC}%
			\makipickfirstfont{Source Han Sans SC,Noto Sans CJK SC,FandolHei-Regular.otf}{FandolHei-Regular.otf}%
			\setCJKsansfont{\MakiPickedFont}%
			\makipickfirstfont{Source Han Sans SC,Noto Sans CJK SC,FandolFang-Regular.otf}{FandolFang-Regular.otf}%
			\setCJKmonofont{\MakiPickedFont}%
			\makipickfirstfont{LXGW WenKai,FandolKai-Regular.otf}{FandolKai-Regular.otf}%
			\setCJKfamilyfont{makiKai}{\MakiPickedFont}%
			\setCJKfamilyfont{makiHeavyKai}{\MakiPickedFont}[AutoFakeBold = 10]%
		}{%
			\PackageWarningNoLine{maki-notes}{Font preset `linux' requested but no supported Linux CJK serif font was found. Falling back to `common'}%
			\makisetcommoncjkfonts
		}%
	}%
}

\newcommand{\makiapplyfontpresetauto}{%
	\IfFontExistsTF{Songti SC}{%
		\makiapplyfontpresetmacos
	}{%
		\IfFontExistsTF{SimSun}{%
			\makiapplyfontpresetwindows
		}{%
			\IfFontExistsTF{Noto Serif CJK SC}{%
				\makiapplyfontpresetlinux
			}{%
				\IfFontExistsTF{Source Han Serif SC}{%
					\makiapplyfontpresetlinux
				}{%
					\makiapplyfontpresetcommon
				}%
			}%
		}%
	}%
}

\newcommand{\makiapplyfontpreset}{%
	\ifcsname makiapplyfontpreset\MakiFontPreset\endcsname
		\csname makiapplyfontpreset\MakiFontPreset\endcsname
	\else
		\PackageError{maki-notes}{Unsupported fontpreset `\MakiFontPreset'}{Valid values are common, auto, windows, macos, linux. Falling back to `common'.}%
		\makiapplyfontpresetcommon
	\fi
}

