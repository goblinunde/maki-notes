\makeatletter

\newcommand{\maki@marginnoteformatright}[1]{%
	\begin{tabular}{@{}p{\MakiMarginRuleWidth}@{\hspace{\MakiMarginNoteGap}}>{\raggedright\arraybackslash}p{\dimexpr\marginparwidth-\MakiMarginRuleWidth-\MakiMarginNoteGap\relax}@{}}%
		{\color{LogicColor}\vrule width \MakiMarginRuleWidth} & #1
	\end{tabular}%
}

\newcommand{\maki@marginnoteformatleft}[1]{%
	\begin{tabular}{@{}>{\raggedleft\arraybackslash}p{\dimexpr\marginparwidth-\MakiMarginRuleWidth-\MakiMarginNoteGap\relax}@{\hspace{\MakiMarginNoteGap}}p{\MakiMarginRuleWidth}@{}}%
		#1 & {\color{LogicColor}\vrule width \MakiMarginRuleWidth}
	\end{tabular}%
}

\newcommand{\maki@marginnotebody}[2]{%
	{\footnotesize\linespread{1.12}\selectfont\color{MainText!85}%
	\ifstrempty{#1}{}{%
		{\color{LogicColor}\heavykaishu #1}\par\vspace{0.18em}%
	}%
	#2}%
}

\newcommand{\maki@outernote}[2]{%
	\marginnote{%
		\checkoddpage
		\if@twoside
			\ifoddpage
				\maki@marginnoteformatright{\maki@marginnotebody{#1}{#2}}%
			\else
				\maki@marginnoteformatleft{\maki@marginnotebody{#1}{#2}}%
			\fi
		\else
			\maki@marginnoteformatright{\maki@marginnotebody{#1}{#2}}%
		\fi
	}%
}

\newcommand{\maki@wrapfigurestyle}{%
	\captionsetup{type=figure}%
	\setlength{\columnsep}{\MakiWrapColumnSep}%
	\setlength{\intextsep}{\MakiWrapTextSep}%
}

\NewDocumentEnvironment{leftfiguretext}{o m +b}{%
	\IfNoValueTF{#1}
		{\begin{wrapfigure}{l}{#2}}
		{\begin{wrapfigure}[#1]{l}{#2}}%
	\maki@wrapfigurestyle
	#3
}{%
	\end{wrapfigure}
}

\NewDocumentEnvironment{rightfiguretext}{o m +b}{%
	\IfNoValueTF{#1}
		{\begin{wrapfigure}{r}{#2}}
		{\begin{wrapfigure}[#1]{r}{#2}}%
	\maki@wrapfigurestyle
	#3
}{%
	\end{wrapfigure}
}

\NewDocumentEnvironment{figuretextleft}{o m +b}{%
	\IfNoValueTF{#1}
		{\begin{leftfiguretext}{#2}}
		{\begin{leftfiguretext}[#1]{#2}}%
	#3
	\end{leftfiguretext}
}{}

\NewDocumentEnvironment{figuretextright}{o m +b}{%
	\IfNoValueTF{#1}
		{\begin{rightfiguretext}{#2}}
		{\begin{rightfiguretext}[#1]{#2}}%
	#3
	\end{rightfiguretext}
}{}

\NewDocumentCommand{\wrapcaption}{m}{\caption{#1}}

\NewDocumentCommand{\sidenote}{m}{%
	\maki@outernote{}{#1}%
}

\NewDocumentCommand{\marginremark}{o m}{%
	\IfNoValueTF{#1}
		{\maki@outernote{}{#2}}
		{\maki@outernote{#1}{#2}}%
}

\NewDocumentCommand{\sidecaptionof}{m m}{%
	\refstepcounter{#1}%
	\marginremark[\csname fnum@#1\endcsname]{#2}%
}

\NewDocumentCommand{\sidecaption}{m}{%
	\sidecaptionof{figure}{#1}%
}

